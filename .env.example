# Copy to .env and fill values
SFTP_HOST=example.hostingraja.in
SFTP_PORT=22
SFTP_USERNAME=your_username
SFTP_PASSWORD=your_password
SFTP_REMOTE_BASE=/photos
WHATSAPP_GROUP_NAME=Friends Media

# Poll interval in seconds for checking new WhatsApp media.
POLL_INTERVAL_SECONDS=60

# Browser profile directory stores WhatsApp Web login session (QR auth cache).
# Relative path is from project root. You can also set an absolute path.
BROWSER_PROFILE_DIR=./state/browser_profile
WHATSAPP_BROWSER=auto

# Local destination root for organized photos (YYYY/MM/DD folders).
# Relative path is from project root. You can also set an absolute path like D:/PhotoArchive.
LOCAL_PHOTOS_ROOT=./photos

# Local destination root for organized videos (YYYY/MM/DD folders).
# Relative path is from project root. You can also set an absolute path like D:/VideoArchive.
LOCAL_VIDEOS_ROOT=./videos

# Optional tuning
UPLOAD_MAX_RETRIES=5
UPLOAD_RETRY_BASE_SECONDS=2
UPLOAD_WORKER_COUNT=2
UPLOAD_MAX_INFLIGHT=4
UPLOAD_BATCH_LIMIT_PER_CYCLE=20
DELETE_LOCAL_AFTER_UPLOAD=true
CLEANUP_EXISTING_UPLOADED_ON_STARTUP=false
WHATSAPP_STARTUP_TIMEOUT_SECONDS=180
WHATSAPP_DOWNLOAD_TIMEOUT_SECONDS=30
